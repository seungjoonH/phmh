# 로컬 포트 (기본값: lib/edit/ports.mjs — dev 4100, edit 4101, edit-server 4102)
# PHMH_EDIT_SERVER_PORT=4102
# NEXT_PUBLIC_PHMH_EDIT_SERVER_URL=http://127.0.0.1:4102

# Contact 메일 SSOT — 센터별 수신처·Resend API 키 (.env)
KOREA_CONTACT_EMAIL=you@example.com
KOREA_RESEND_API_KEY=re_xxxxxxxx
PHILIPPINES_CONTACT_EMAIL=you@example.com
PHILIPPINES_RESEND_API_KEY=re_xxxxxxxx

# 선택: 발신 덮어쓰기 (없으면 `contact@{수신 도메인}` 자동)
# RESEND_FROM=PHMH Contact <contact@phmhservices.com>
# 로컬은 기본 sandbox 발신(onboarding@resend.dev). 운영 발신 강제 시:
# RESEND_SANDBOX=false
