{
  "name": "phmh",
  "version": "1.0.17", 
  "private": true,
  "imports": {
    "#phmh/contact-form-structure": {
      "node": "./lib/contact-form-structure-runtime.mjs",
      "default": "./lib/contact-form-structure.ts"
    }
  },
  "scripts": {
    "dev": "next dev -p 4100",
    "edit": "node scripts/run-edit.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scrape": "node scripts/scrape-wix-content.mjs",
    "locales": "node scripts/build-locales-from-scrape.mjs && node scripts/build-ko-locale.mjs",
    "images:placeholders": "node scripts/fetch-placeholder-images.mjs",
    "test:locale": "node --experimental-strip-types scripts/check-locale-keys.mjs",
    "test:locale-structure": "node --experimental-strip-types scripts/check-locale-structure.mjs",
    "test:therapists": "node scripts/check-therapists.mjs",
    "test:centers": "node scripts/check-centers.mjs",
    "test:inline-markup": "node --experimental-strip-types scripts/test-inline-markup-edit.mjs",
    "test:pending-keys": "node --experimental-strip-types scripts/test-pending-keys.mjs",
    "test:text-edit-history": "node --experimental-strip-types scripts/test-text-edit-history.mjs"
  },
  "dependencies": {
    "motion": "^12.38.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^6.12.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cheerio": "^1.0.0",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
